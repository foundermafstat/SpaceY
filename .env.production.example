# Next.js production server
HOSTNAME=127.0.0.1
PORT=7790
NEXT_PUBLIC_ALLOW_BROWSER_AUTH=false
BATTLE_WS_PUBLIC_URL=wss://spacey.aima.space/realtime/v1/battle
PVP_MATCHMAKING_ENABLED=false
PVP_MATCH_CLAIM_LEASE_SECONDS=15

# Private admin non-secret configuration. DATABASE_URL, VALKEY_URL,
# ADMIN_AUTH_RATE_LIMIT_KEY and ADMIN_TOTP_KEYRING are injected from /etc/spacey.
ADMIN_ALLOWED_ORIGINS=https://admin.spacey.aima.space
ADMIN_WEBAUTHN_ORIGIN=https://admin.spacey.aima.space
ADMIN_WEBAUTHN_RP_ID=spacey.aima.space
ADMIN_WEBAUTHN_RP_NAME=SpaceY Admin
ADMIN_WEBAUTHN_CHALLENGE_TTL_SECONDS=300
ADMIN_SESSION_TTL_SECONDS=28800
ADMIN_AUTH_RATE_LIMIT_MAX=10
ADMIN_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
ADMIN_TOTP_MAX_ATTEMPTS=5
ADMIN_TOTP_LOCKOUT_SECONDS=900
ADMIN_TOTP_WINDOW=1

# Jobs retention cadence. Legal/operational cutoffs are fixed in code and DB.
RETENTION_MAINTENANCE_INTERVAL_MS=300000
RETENTION_MAINTENANCE_BATCH_SIZE=5000

# Secrets are loaded from root-owned files under /etc/spacey and are never stored here.
