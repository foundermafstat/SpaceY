{
  "name": "@spacey/game-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:stack": "turbo run dev --parallel",
    "build": "next build",
    "build:all": "turbo run build && pnpm run build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "pnpm run typecheck && turbo run typecheck",
    "test": "pnpm --filter @spacey/protocol build && node --experimental-strip-types --test tests/*.test.mjs",
    "test:all": "pnpm run test && turbo run test",
    "validate:load-harness": "node --check load/k6/spacey-pvp-acceptance.mjs && node --check load/k6/battle-protobuf.mjs && node scripts/validate-load-harness.mjs && node scripts/verify-load-headroom.mjs --self-test",
    "validate:assets": "node scripts/validate-asset-pipeline.mjs",
    "smoke:playable": "node scripts/smoke-playable.mjs"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.0",
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@spacey/contracts": "workspace:*",
    "@spacey/protocol": "workspace:*",
    "@tma.js/sdk-react": "^3.0.22",
    "animejs": "^4.5.0",
    "gsap": "^3.15.0",
    "next": "16.2.9",
    "postprocessing": "^6.39.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.7.0",
    "three": "0.185.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.185.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
