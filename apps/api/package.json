{
  "name": "@spacey/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --import @spacey/observability/register dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "@aws-sdk/s3-request-presigner": "^3.1083.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/swagger": "^11.2.1",
    "@spacey/contracts": "workspace:*",
    "@spacey/db": "workspace:*",
    "@spacey/observability": "workspace:*",
    "@spacey/protocol": "workspace:*",
    "@spacey/simulation": "workspace:*",
    "fastify": "^5.7.4",
    "ioredis": "^5.7.0",
    "jose": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
