{
  "name": "@spacey/battle-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --import @spacey/observability/register dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "@spacey/contracts": "workspace:*",
    "@spacey/db": "workspace:*",
    "@spacey/observability": "workspace:*",
    "@spacey/protocol": "workspace:*",
    "@spacey/simulation": "workspace:*",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "protobufjs": "^8.7.0",
    "ws": "^8.21.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
