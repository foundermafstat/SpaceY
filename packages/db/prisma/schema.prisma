  createdAt               DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  missionAttempt          MissionAttempt?     @relation(fields: [missionAttemptId], references: [id], onDelete: Cascade)
  pvpMatch                PvpMatch?           @relation(fields: [pvpMatchId], references: [id], onDelete: Cascade)
  contentRelease          ContentRelease      @relation(fields: [contentReleaseId], references: [id], onDelete: Restrict)
  checkpoints             BattleCheckpoint[]
  inputJournal            InputJournal[]

  @@index([missionAttemptId])
  @@index([pvpMatchId])
  @@index([contentReleaseId])
  @@index([status, workerId, updatedAt])
  @@index([createdAt, id])
  @@map("battle_sessions")
}

model BattleCheckpoint {
  id              String        @id @db.Uuid
  battleSessionId String        @map("battle_session_id") @db.Uuid
  sequence        Int
  tick            Int
  inputSequence   BigInt        @map("input_sequence")
  statePayload    Bytes         @map("state_payload")
  stateHash       String        @map("state_hash")
  expiresAt       DateTime      @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  battleSession   BattleSession @relation(fields: [battleSessionId], references: [id], onDelete: Cascade)

  @@unique([battleSessionId, sequence])
  @@unique([battleSessionId, tick])
  @@index([battleSessionId])
  @@index([expiresAt])
  @@index([createdAt, id])
  @@map("battle_checkpoints")
}

model InputJournal {
  id              String        @id @db.Uuid
  battleSessionId String        @map("battle_session_id") @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  sequence        BigInt
  clientSequence  BigInt        @map("client_sequence")
  targetTick      Int           @map("target_tick")
  inputType       String        @map("input_type")
  payload         Json
  metadata        Json          @default("{}")
  idempotencyKey  String        @unique @map("idempotency_key")
  receivedAt      DateTime      @default(now()) @map("received_at") @db.Timestamptz(6)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  battleSession   BattleSession @relation(fields: [battleSessionId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([battleSessionId, sequence])
  @@unique([battleSessionId, userId, clientSequence])
  @@index([battleSessionId])
  @@index([userId])
  @@index([battleSessionId, targetTick, sequence])
  @@index([userId, createdAt, id])
  @@index([createdAt, id])
  @@map("input_journal")
}

model LegacyBuildImport {
  id                  String             @id @db.Uuid
  userId              String             @unique @map("user_id") @db.Uuid
  importedBuildId     String?            @unique @map("imported_build_id") @db.Uuid
  sourceSchemaVersion Int                @default(3) @map("source_schema_version")
  sourceHash          String             @map("source_hash")
  sourceSnapshot      Json               @map("source_snapshot")
  status              LegacyImportStatus @default(PENDING)
  idempotencyKey      String             @unique @map("idempotency_key")
  errorCode           String?            @map("error_code")
  importedAt          DateTime?          @map("imported_at") @db.Timestamptz(6)
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedBuild       ShipBuild?         @relation(fields: [importedBuildId], references: [id], onDelete: SetNull)

  @@unique([userId, sourceHash])
  @@index([importedBuildId])
  @@index([status, createdAt])
  @@index([createdAt, id])
  @@map("legacy_build_imports")
}

model PlayerCommandIdempotency {
  id          String              @id @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  scope       String
  key         String
  requestHash String              @map("request_hash")
  status      PlayerCommandStatus @default(RUNNING)
  response    Json?
  errorCode   String?             @map("error_code")
  expiresAt   DateTime            @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope, key])
  @@index([userId])
  @@index([expiresAt])
  @@index([userId, createdAt, id])
  @@index([createdAt, id])
  @@map("player_command_idempotency")
}

model PlayerProgression {
  id         String   @id @db.Uuid
  userId     String   @unique @map("user_id") @db.Uuid
  level      Int      @default(1)
  experience BigInt   @default(0)
  reputation BigInt   @default(0)
  version    BigInt   @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt, id])
  @@map("player_progression")
}

model ResearchDefinition {
  id               String         @id @db.Uuid
  contentReleaseId String         @map("content_release_id") @db.Uuid
  key              String
  cost             Json
  prerequisites    Json           @default("[]")
  effects          Json
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  contentRelease   ContentRelease @relation(fields: [contentReleaseId], references: [id], onDelete: Restrict)
  userResearch     UserResearch[]

  @@unique([contentReleaseId, key])
  @@index([contentReleaseId])
  @@index([createdAt, id])
  @@map("research_definitions")
}

model UserResearch {
  id                   String             @id @db.Uuid
  userId               String             @map("user_id") @db.Uuid
  researchDefinitionId String             @map("research_definition_id") @db.Uuid
  status               ResearchStatus     @default(LOCKED)
  progress             Int                @default(0)
  startedAt            DateTime?          @map("started_at") @db.Timestamptz(6)
  completedAt          DateTime?          @map("completed_at") @db.Timestamptz(6)
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  researchDefinition   ResearchDefinition @relation(fields: [researchDefinitionId], references: [id], onDelete: Restrict)

  @@unique([userId, researchDefinitionId])
  @@index([userId])
  @@index([researchDefinitionId])
  @@index([userId, status, createdAt, id])
  @@index([createdAt, id])
  @@map("user_research")
}

model AchievementDefinition {
  id               String            @id @db.Uuid
  contentReleaseId String            @map("content_release_id") @db.Uuid
  key              String
  criteria         Json
  rewards          Json
  hidden           Boolean           @default(false)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  contentRelease   ContentRelease    @relation(fields: [contentReleaseId], references: [id], onDelete: Restrict)
  userAchievements UserAchievement[]

  @@unique([contentReleaseId, key])
  @@index([contentReleaseId])
  @@index([createdAt, id])
  @@map("achievement_definitions")
}

model UserAchievement {
  id                      String                @id @db.Uuid
  userId                  String                @map("user_id") @db.Uuid
  achievementDefinitionId String                @map("achievement_definition_id") @db.Uuid
  progress                BigInt                @default(0)
  completedAt             DateTime?             @map("completed_at") @db.Timestamptz(6)
  claimedAt               DateTime?             @map("claimed_at") @db.Timestamptz(6)
  createdAt               DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementDefinition   AchievementDefinition @relation(fields: [achievementDefinitionId], references: [id], onDelete: Restrict)

  @@unique([userId, achievementDefinitionId])
  @@index([userId])
  @@index([achievementDefinitionId])
  @@index([userId, completedAt, createdAt, id])
  @@index([createdAt, id])
  @@map("user_achievements")
}

model Season {
  id                 String              @id @db.Uuid
  key                String              @unique
  status             SeasonStatus        @default(DRAFT)
  rules              Json
  startsAt           DateTime            @map("starts_at") @db.Timestamptz(6)
  endsAt             DateTime            @map("ends_at") @db.Timestamptz(6)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  participants       SeasonParticipant[]
  matchmakingTickets MatchmakingTicket[]

  @@index([status, startsAt, endsAt])
  @@index([createdAt, id])
  @@map("seasons")
}

model SeasonParticipant {
  id        String   @id @db.Uuid
  seasonId  String   @map("season_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  rating    Int      @default(1000)
  tier      String   @default("unranked")
  wins      Int      @default(0)
  losses    Int      @default(0)
  draws     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@index([seasonId])
  @@index([userId])
  @@index([seasonId, rating, id])
  @@index([userId, createdAt, id])
  @@index([createdAt, id])
  @@map("season_participants")
}

model StarsPaymentEvent {
  id                      String                @id @db.Uuid
  userId                  String?               @map("user_id") @db.Uuid
  telegramUpdateId        BigInt                @unique @map("telegram_update_id")
  telegramPaymentChargeId String?               @unique @map("telegram_payment_charge_id")
  providerPaymentChargeId String?               @unique @map("provider_payment_charge_id")
  invoicePayload          String                @map("invoice_payload")
  eventType               StarsPaymentEventType @map("event_type")
  totalAmount             BigInt                @map("total_amount")
  currency                String                @default("XTR")
  rawEvent                Json                  @map("raw_event")
  idempotencyKey          String                @unique @map("idempotency_key")
  processedAt             DateTime?             @map("processed_at") @db.Timestamptz(6)
  createdAt               DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  user                    User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([invoicePayload, createdAt])
  @@index([eventType, createdAt])
  @@index([createdAt, id])
  @@map("stars_payment_events")
}
