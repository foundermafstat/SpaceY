generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED

  @@map("user_status")
}

enum AuthSessionStatus {
  ACTIVE
  ROTATED
  REVOKED
  EXPIRED

  @@map("auth_session_status")
}

enum ContentReleaseStatus {
  DRAFT
  PUBLISHED
  RETIRED

  @@map("content_release_status")
}

enum BuildStatus {
  ACTIVE
  ARCHIVED

  @@map("build_status")
}

enum InventoryItemState {
  AVAILABLE
  INSTALLED
  DAMAGED
  DESTROYED
  CONSUMED

  @@map("inventory_item_state")
}

enum WalletCurrency {
  CREDITS
  SCRAP
  ALLOY
  DATA_SHARDS
  STARS

  @@map("wallet_currency")
}

enum MissionAttemptType {
  PVE
  PVP

  @@map("mission_attempt_type")
}

enum MissionAttemptStatus {
  CREATED
  CONNECTING
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
  ABANDONED

  @@map("mission_attempt_status")
}

enum MissionType {
  SALVAGE
  ESCORT
  MINING
  INTERCEPT
  DEFENSE

  @@map("mission_type")
}

enum MissionRisk {
  GREEN
  YELLOW
  RED

  @@map("mission_risk")
}

enum MissionOutcome {
  VICTORY
  DEFEAT
  DRAW
  FORFEIT
  ERROR

  @@map("mission_outcome")
}

enum PvpMatchStatus {
  MATCHED
  CONNECTING
  ACTIVE
  COMPLETED
  CANCELLED

  @@map("pvp_match_status")
}

enum MatchmakingTicketStatus {
  QUEUED
  MATCHED
  COMPLETED
  CANCELLED
  EXPIRED
  FAILED

  @@map("matchmaking_ticket_status")
}

enum ApiClientStatus {
  ACTIVE
  SUSPENDED
  REVOKED

  @@map("api_client_status")
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  REVOKED

  @@map("webhook_status")
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERING
  DELIVERED
  FAILED
  DEAD

  @@map("webhook_delivery_status")
}

enum AdminUserStatus {
  ACTIVE
  SUSPENDED
  REVOKED

  @@map("admin_user_status")
}

enum AdminAuthenticationMethod {
  WEBAUTHN
  TOTP_RECOVERY

  @@map("admin_authentication_method")
}

enum AdminWebAuthnChallengePurpose {
  AUTHENTICATION
  REGISTRATION

  @@map("admin_webauthn_challenge_purpose")
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED

  @@map("outbox_status")
}

enum JobStatus {
  RUNNING
  SUCCEEDED
  FAILED

  @@map("job_status")
}

enum StarsPaymentEventType {
  PRE_CHECKOUT
  PAID
  REFUNDED
  CHARGEBACK

  @@map("stars_payment_event_type")
}

enum TelegramBotUpdateStatus {
  PROCESSING
  COMPLETED

  @@map("telegram_bot_update_status")
}

enum TelegramSupportTicketStatus {
  OPEN
  CLOSED

  @@map("telegram_support_ticket_status")
}

enum TelegramSupportMessageKind {
  REQUEST
  MESSAGE

  @@map("telegram_support_message_kind")
}

enum SeasonStatus {
  DRAFT
  ACTIVE
  COMPLETED

  @@map("season_status")
}

enum ResearchStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED

  @@map("research_status")
}

enum BattleSessionStatus {
  CREATED
  ACTIVE
  PAUSED
  RECOVERING
  ENDED
  FAILED

  @@map("battle_session_status")
}

enum LegacyImportStatus {
  PENDING
  IMPORTED
  REJECTED

  @@map("legacy_import_status")
}

enum PlayerCommandStatus {
  RUNNING
  SUCCEEDED
  FAILED

  @@map("player_command_status")
}

enum PrivacyRequestType {
  EXPORT
  DELETE

  @@map("privacy_request_type")
}

enum PrivacyRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED

  @@map("privacy_request_status")
}

model User {
  id                   String                     @id @db.Uuid
  status               UserStatus                 @default(ACTIVE)
  displayName          String?                    @map("display_name")
  locale               String                     @default("en")
  timeZone             String                     @default("UTC") @map("time_zone")
  avatarUrl            String?                    @map("avatar_url")
  profilePublic        Boolean                    @default(false) @map("profile_public")
  analyticsConsentAt   DateTime?                  @map("analytics_consent_at") @db.Timestamptz(6)
  analyticsConsentUpdatedAt DateTime?             @map("analytics_consent_updated_at") @db.Timestamptz(6)
  termsAcceptedAt      DateTime?                  @map("terms_accepted_at") @db.Timestamptz(6)
  createdAt            DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  telegramIdentity     TelegramIdentity?
  telegramAuthReplays  TelegramAuthReplay[]
  authSessions         AuthSession[]
  shipBuilds           ShipBuild[]
  inventoryItems       InventoryItem[]
  inventoryTransitions InventoryTransition[]
  walletBalances       WalletBalance[]
  walletLedgerEntries  WalletLedgerEntry[]
  missionAttempts      MissionAttempt[]
  pvpParticipants      PvpMatchParticipant[]
  matchmakingTickets   MatchmakingTicket[]
  apiClients           ApiClient[]
  starsPaymentEvents   StarsPaymentEvent[]
  progression          PlayerProgression?
  research             UserResearch[]
  achievements         UserAchievement[]
  seasonParticipants   SeasonParticipant[]
  inputJournalEntries  InputJournal[]
  legacyBuildImport    LegacyBuildImport?
  commandIdempotency   PlayerCommandIdempotency[]
  privacyRequests      PrivacyRequest[]
  adminUser            AdminUser?

  @@index([status, createdAt, id])
  @@index([createdAt, id])
  @@map("users")
}

model TelegramIdentity {
  id             String   @id @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  telegramUserId BigInt   @unique @map("telegram_user_id")
  username       String?
  firstName      String?  @map("first_name")
  lastName       String?  @map("last_name")
  languageCode   String?  @map("language_code")
  isPremium      Boolean  @default(false) @map("is_premium")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt, id])
  @@map("telegram_identities")
}

model TelegramAuthReplay {
  id             String   @id @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  initDataHash   String   @unique @map("init_data_hash")
  telegramUserId BigInt?  @map("telegram_user_id")
  authDate       DateTime @map("auth_date") @db.Timestamptz(6)
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user           User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt, id])
  @@map("telegram_auth_replays")
}

model TelegramBotUpdate {
  updateId     BigInt                  @id @map("update_id")
  status       TelegramBotUpdateStatus @default(PROCESSING)
  claimedAt    DateTime                @default(now()) @map("claimed_at") @db.Timestamptz(6)
  completedAt  DateTime?               @map("completed_at") @db.Timestamptz(6)
  attemptCount Int                     @default(1) @map("attempt_count")
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, claimedAt])
  @@index([createdAt, updateId])
  @@map("telegram_bot_updates")
}

model TelegramReferral {
  id               String   @id @db.Uuid
  telegramUserId   BigInt   @map("telegram_user_id")
  referralCode     String   @map("referral_code")
  telegramUpdateId BigInt   @unique @map("telegram_update_id")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([telegramUserId, createdAt])
  @@index([referralCode, createdAt])
  @@index([createdAt, id])
  @@map("telegram_referrals")
}

model TelegramSupportTicket {
  id             String                      @id @db.Uuid
  telegramUserId BigInt                      @map("telegram_user_id")
  chatId         BigInt                      @map("chat_id")
  status         TelegramSupportTicketStatus @default(OPEN)
  openedAt       DateTime                    @default(now()) @map("opened_at") @db.Timestamptz(6)
  closedAt       DateTime?                   @map("closed_at") @db.Timestamptz(6)
  createdAt      DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  messages       TelegramSupportMessage[]

  @@index([telegramUserId, status, updatedAt])
  @@index([status, updatedAt])
  @@index([createdAt, id])
  @@map("telegram_support_tickets")
}

model TelegramSupportMessage {
  id               String                     @id @db.Uuid
  ticketId         String                     @map("ticket_id") @db.Uuid
  telegramUpdateId BigInt                     @unique @map("telegram_update_id")
  telegramUserId   BigInt                     @map("telegram_user_id")
  chatId           BigInt                     @map("chat_id")
  kind             TelegramSupportMessageKind
  text             String
  createdAt        DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  ticket           TelegramSupportTicket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([telegramUserId, createdAt])
  @@index([createdAt, id])
  @@map("telegram_support_messages")
}

model TelegramNotificationPreference {
  telegramUserId BigInt   @id @map("telegram_user_id")
  enabled        Boolean  @default(true)
  sourceUpdateId BigInt   @unique @map("source_update_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([enabled, updatedAt])
  @@map("telegram_notification_preferences")
}

model AuthSession {
  id               String            @id @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  tokenFamily      String            @map("token_family") @db.Uuid
  refreshTokenHash String            @unique @map("refresh_token_hash")
  status           AuthSessionStatus @default(ACTIVE)
  rotatedFromId    String?           @map("rotated_from_id") @db.Uuid
  replacedById     String?           @unique @map("replaced_by_id") @db.Uuid
  reuseDetectedAt  DateTime?         @map("reuse_detected_at") @db.Timestamptz(6)
  expiresAt        DateTime          @map("expires_at") @db.Timestamptz(6)
  lastUsedAt       DateTime?         @map("last_used_at") @db.Timestamptz(6)
  revokedAt        DateTime?         @map("revoked_at") @db.Timestamptz(6)
  ipHash           String?           @map("ip_hash")
  userAgentHash    String?           @map("user_agent_hash")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  rotatedFrom      AuthSession?      @relation("SessionRotation", fields: [rotatedFromId], references: [id], onDelete: SetNull)
  replacements     AuthSession[]     @relation("SessionRotation")
  replacedBy       AuthSession?      @relation("SessionReplacement", fields: [replacedById], references: [id], onDelete: SetNull)
  replacedSession  AuthSession?      @relation("SessionReplacement")

  @@index([userId])
  @@index([rotatedFromId])
  @@index([tokenFamily, createdAt])
  @@index([userId, status, expiresAt])
  @@index([createdAt, id])
  @@map("auth_sessions")
}

model PrivacyRequest {
  id                        String               @id @db.Uuid
  userId                    String               @map("user_id") @db.Uuid
  type                      PrivacyRequestType
  status                    PrivacyRequestStatus @default(PENDING)
  requestHash               String               @map("request_hash")
  idempotencyKey            String               @map("idempotency_key")
  requestedAt               DateTime             @default(now()) @map("requested_at") @db.Timestamptz(6)
  processingStartedAt       DateTime?            @map("processing_started_at") @db.Timestamptz(6)
  completedAt               DateTime?            @map("completed_at") @db.Timestamptz(6)
  failedAt                  DateTime?            @map("failed_at") @db.Timestamptz(6)
  failureCode               String?              @map("failure_code")
  exportObjectKey           String?              @map("export_object_key")
  exportObjectVersion       String?              @map("export_object_version")
  exportContentType         String?              @map("export_content_type")
  exportContentSha256       String?              @map("export_content_sha256")
  exportSizeBytes           BigInt?              @map("export_size_bytes")
  exportEncryptionAlgorithm String?              @map("export_encryption_algorithm")
  exportEncryptionKeyId     String?              @map("export_encryption_key_id")
  exportExpiresAt           DateTime?            @map("export_expires_at") @db.Timestamptz(6)
  anonymizedAt              DateTime?            @map("anonymized_at") @db.Timestamptz(6)
  retentionPolicyVersion    String               @default("eu-v1") @map("retention_policy_version")
  retentionUntil            DateTime             @map("retention_until") @db.Timestamptz(6)
  createdAt                 DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                      User                 @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, idempotencyKey])
  @@index([userId])
  @@index([userId, requestedAt, id])
  @@index([status, requestedAt, id])
  @@index([retentionUntil])
  @@map("privacy_requests")
}

model ContentRelease {
  id                     String                  @id @db.Uuid
  version                String                  @unique
  status                 ContentReleaseStatus    @default(DRAFT)
  configHash             String                  @unique @map("config_hash")
  schemaVersion          Int                     @map("schema_version")
  bootstrapConfig        Json                    @default("{}") @map("bootstrap_config")
  notes                  String?
  createdByAdminId       String?                 @map("created_by_admin_id") @db.Uuid
  publishedAt            DateTime?               @map("published_at") @db.Timestamptz(6)
  createdAt              DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  missions               MissionDefinition[]
  buildRevisions         ShipBuildRevision[]
  inventoryItems         InventoryItem[]
  missionAttempts        MissionAttempt[]
  pvpMatches             PvpMatch[]
  matchmakingTickets     MatchmakingTicket[]
  moduleDefinitions      ModuleDefinition[]
  enemyDefinitions       EnemyDefinition[]
  dropTables             DropTable[]
  battleSessions         BattleSession[]
  researchDefinitions    ResearchDefinition[]
  achievementDefinitions AchievementDefinition[]
  createdByAdmin         AdminUser?              @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)

  @@index([createdByAdminId])
  @@index([status, publishedAt])
  @@index([createdAt, id])
  @@map("content_releases")
}

model MissionDefinition {
  id                 String              @id @db.Uuid
  contentReleaseId   String              @map("content_release_id") @db.Uuid
  dropTableId        String?             @map("drop_table_id") @db.Uuid
  key                String
  type               MissionType
  risk               MissionRisk
  title              String
  description        String
  objective          Json
  enemyRoster        Json                @map("enemy_roster")
  rewardDefinition   Json                @map("reward_definition")
  durationSeconds    Int                 @map("duration_seconds")
  enabled            Boolean             @default(true)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  contentRelease     ContentRelease      @relation(fields: [contentReleaseId], references: [id], onDelete: Restrict)
  dropTable          DropTable?          @relation(fields: [dropTableId], references: [id], onDelete: Restrict)
  missionAttempts    MissionAttempt[]
  matchmakingTickets MatchmakingTicket[]

  @@unique([contentReleaseId, key])
  @@index([contentReleaseId])
  @@index([dropTableId])
  @@index([type, risk, enabled])
  @@index([enabled, key])
  @@index([createdAt, id])
  @@map("mission_definitions")
}

model ShipBuild {
  id                String              @id @db.Uuid
  userId            String              @map("user_id") @db.Uuid
  name              String
  status            BuildStatus         @default(ACTIVE)
  currentRevisionId String?             @unique @map("current_revision_id") @db.Uuid
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentRevision   ShipBuildRevision?  @relation("CurrentBuildRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)
  revisions         ShipBuildRevision[] @relation("BuildRevisions")
  legacyImport      LegacyBuildImport?

  @@unique([userId, name])
  @@index([userId])
  @@index([status, updatedAt])
  @@index([createdAt, id])
  @@map("ship_builds")
}

model ShipBuildRevision {
  id                 String                @id @db.Uuid
  buildId            String                @map("build_id") @db.Uuid
  contentReleaseId   String                @map("content_release_id") @db.Uuid
  version            Int
  schemaVersion      Int                   @map("schema_version")
  snapshot           Json
  snapshotHash       String                @map("snapshot_hash")
  totalMass          Int                   @map("total_mass")
  totalPower         Int                   @map("total_power")
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  build              ShipBuild             @relation("BuildRevisions", fields: [buildId], references: [id], onDelete: Cascade)
  currentForBuild    ShipBuild?            @relation("CurrentBuildRevision")
  contentRelease     ContentRelease        @relation(fields: [contentReleaseId], references: [id], onDelete: Restrict)
  installedItems     BuildRevisionItem[]
  missionAttempts    MissionAttempt[]
  pvpParticipants    PvpMatchParticipant[]
  matchmakingTickets MatchmakingTicket[]

  @@unique([buildId, version])
  @@unique([buildId, snapshotHash])
  @@index([buildId])
  @@index([contentReleaseId])
  @@index([createdAt, id])
  @@map("ship_build_revisions")
}

model InventoryItem {
  id               String                @id @db.Uuid
  userId           String                @map("user_id") @db.Uuid
  contentReleaseId String                @map("content_release_id") @db.Uuid
  definitionKey    String                @map("definition_key")
  state            InventoryItemState    @default(AVAILABLE)
  durability       Int                   @default(10000)
  metadata         Json                  @default("{}")
  acquiredAt       DateTime              @default(now()) @map("acquired_at") @db.Timestamptz(6)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentRelease   ContentRelease        @relation(fields: [contentReleaseId], references: [id], onDelete: Restrict)
  installations    BuildRevisionItem[]
  transitions      InventoryTransition[]

  @@index([userId])
  @@index([contentReleaseId])
  @@index([userId, state, createdAt, id])
  @@index([definitionKey, state])
  @@index([createdAt, id])
  @@map("inventory_items")
}

model BuildRevisionItem {
  id              String            @id @db.Uuid
  buildRevisionId String            @map("build_revision_id") @db.Uuid
  inventoryItemId String            @map("inventory_item_id") @db.Uuid
  slotKey         String            @map("slot_key")
  placement       Json
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  buildRevision   ShipBuildRevision @relation(fields: [buildRevisionId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([buildRevisionId, slotKey])
  @@unique([buildRevisionId, inventoryItemId])
  @@index([buildRevisionId])
  @@index([inventoryItemId])
  @@index([createdAt, id])
  @@map("build_revision_items")
}

model InventoryTransition {
  id              String              @id @db.Uuid
  userId          String              @map("user_id") @db.Uuid
  inventoryItemId String              @map("inventory_item_id") @db.Uuid
  fromState       InventoryItemState? @map("from_state")
  toState         InventoryItemState  @map("to_state")
  sourceType      String              @map("source_type")
  sourceId        String?             @map("source_id") @db.Uuid
  idempotencyKey  String              @unique @map("idempotency_key")
  metadata        Json                @default("{}")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([inventoryItemId])
  @@index([userId, createdAt, id])
  @@index([sourceType, sourceId])
  @@map("inventory_transitions")
}

model WalletBalance {
  id            String              @id @db.Uuid
  userId        String              @map("user_id") @db.Uuid
  currency      WalletCurrency
  balance       BigInt              @default(0)
  version       BigInt              @default(0)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries WalletLedgerEntry[]

  @@unique([userId, currency])
  @@index([userId])
  @@index([createdAt, id])
  @@map("wallet_balances")
}

model WalletLedgerEntry {
  id              String         @id @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  walletBalanceId String         @map("wallet_balance_id") @db.Uuid
  currency        WalletCurrency
  delta           BigInt
  balanceAfter    BigInt         @map("balance_after")
  sourceType      String         @map("source_type")
  sourceId        String?        @map("source_id") @db.Uuid
  idempotencyKey  String         @unique @map("idempotency_key")
  metadata        Json           @default("{}")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  walletBalance   WalletBalance  @relation(fields: [walletBalanceId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([walletBalanceId])
  @@index([userId, currency, createdAt, id])
  @@index([sourceType, sourceId])
  @@index([createdAt, id])
  @@map("wallet_ledger_entries")
}

model MatchmakingTicket {
  id                  String                  @id @db.Uuid
  userId              String                  @map("user_id") @db.Uuid
  buildRevisionId     String                  @map("build_revision_id") @db.Uuid
  seasonId            String                  @map("season_id") @db.Uuid
  contentReleaseId    String                  @map("content_release_id") @db.Uuid
  missionDefinitionId String                  @map("mission_definition_id") @db.Uuid
  pvpMatchId          String?                 @map("pvp_match_id") @db.Uuid
  queue               String
  region              String
  status              MatchmakingTicketStatus @default(QUEUED)
  mmr                 Int
  baseMmrWindow       Int                     @map("base_mmr_window")
  expansionPerSecond  Int                     @map("expansion_per_second")
  maxMmrWindow        Int                     @map("max_mmr_window")
  requestHash         String                  @map("request_hash")
  idempotencyKey      String                  @unique @map("idempotency_key")
  expiresAt           DateTime                @map("expires_at") @db.Timestamptz(6)
  matchedAt           DateTime?               @map("matched_at") @db.Timestamptz(6)
  cancelledAt         DateTime?               @map("cancelled_at") @db.Timestamptz(6)
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
