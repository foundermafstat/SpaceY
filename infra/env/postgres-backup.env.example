# Non-secret PostgreSQL backup policy. Copy to /etc/spacey/backup/postgres.env (root:root 0600).
SPACEY_ENVIRONMENT=production
SPACEY_REPOSITORY_ROOT=/opt/spacey/current
SPACEY_DATA_COMPOSE_FILE=/opt/spacey/current/infra/compose.production-data.yml
SPACEY_DATA_ENV_FILE=/etc/spacey/data.env
RESTIC_IMAGE=restic/restic@sha256:replace-with-verified-digest
RESTIC_REPOSITORY=s3:https://s3.example.eu/spacey-postgres/production
RESTIC_PASSWORD_FILE=/etc/spacey/backup/restic-password
RESTIC_S3_ENV_FILE=/etc/spacey/backup/s3.env
RESTIC_CACHE_DIR=/var/cache/spacey/restic
BACKUP_EVIDENCE_DIR=/var/lib/spacey/backup-evidence
BACKUP_ARCHIVE_NAME=spacey-postgres.dump
BACKUP_CHECK_SUBSET=5%
BACKUP_KEEP_WITHIN_DAILY=14d
BACKUP_KEEP_WITHIN_WEEKLY=3m
BACKUP_KEEP_WITHIN_MONTHLY=2y
BACKUP_KEEP_WITHIN_YEARLY=3y
BACKUP_MAX_AGE_HOURS=30
