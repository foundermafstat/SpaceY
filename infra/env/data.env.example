# Non-secret production data-plane values. ACL/password files stay under SPACEY_CONFIG_DIR.
SPACEY_DATA_PROJECT=spacey-data
SPACEY_DATA_NETWORK=spacey-data
SPACEY_CONFIG_DIR=/etc/spacey
POSTGRES_IMAGE=postgres@sha256:replace-with-verified-digest
POSTGRES_DATABASE=spacey
POSTGRES_SUPERUSER=spacey_bootstrap
POSTGRES_MAX_CONNECTIONS=400
POSTGRES_CONTAINER_MEMORY_LIMIT=4gb
POSTGRES_SHM_SIZE=1gb
POSTGRES_SHARED_BUFFERS=1gb
POSTGRES_EFFECTIVE_CACHE_SIZE=3gb
POSTGRES_MAINTENANCE_WORK_MEM=256mb
POSTGRES_WORK_MEM=8mb
POSTGRES_LOG_MIN_DURATION_MS=250
VALKEY_IMAGE=valkey/valkey@sha256:replace-with-verified-digest
VALKEY_MAXMEMORY=2gb
VALKEY_CONTAINER_MEMORY_LIMIT=3gb
VALKEY_MAXCLIENTS=10000
VALKEY_LATENCY_MONITOR_MS=100
